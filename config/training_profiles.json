{
  "schema_version": 2,
  "defaults": {
    "optimizer": {
      "name": "adamw",
      "learning_rate": 0.0003,
      "beta1": 0.9,
      "beta2": 0.95,
      "epsilon": 1e-8,
      "weight_decay": 0.1,
      "gradient_clip_norm": 1.0
    },
    "learning_rate": {
      "schedule": "cosine",
      "warmup_steps": 0,
      "warmup_ratio": 0.0,
      "minimum_learning_rate_ratio": 0.1
    },
    "checkpoint": {
      "interval_steps": 100,
      "keep_last": 3,
      "keep_best": 1,
      "save_optimizer": true,
      "save_scheduler": true,
      "save_rng_state": true,
      "require_checksum_manifest": true,
      "require_reload_verification": true
    },
    "evaluation": {
      "interval_steps": 100,
      "validation_batches": 8,
      "suite_path": "config/eval_schedule.json",
      "strict": true,
      "early_stopping_patience": 8,
      "early_stopping_min_delta": 0.001,
      "maximum_validation_regression": 0.03
    },
    "retention": {
      "hot_days": 30,
      "archive_days": 365,
      "delete_after_days": 730,
      "preserve_promoted": true
    },
    "promotion": {
      "require_reload_verification": true,
      "require_passing_evaluation": true,
      "require_no_regression": true,
      "minimum_completed_evaluations": 1,
      "minimum_step": 1
    },
    "retry": {
      "maximum_attempts": 3,
      "initial_backoff_seconds": 30,
      "maximum_backoff_seconds": 900,
      "retryable_failures": ["infrastructure", "preemption", "node_loss", "network", "object_store"],
      "preemption_action": "checkpoint_then_requeue"
    },
    "runtime_limits": {
      "maximum_wall_time_seconds": 86400,
      "heartbeat_interval_seconds": 5,
      "heartbeat_timeout_seconds": 60,
      "graceful_shutdown_seconds": 120
    },
    "dataloader": {
      "workers_per_rank": 4,
      "prefetch_batches": 4,
      "pin_memory": true,
      "persistent_workers": true,
      "deterministic_shuffle": true,
      "seed": 1337,
      "local_cache_gib": 100,
      "cache_path": "/cache/aeitron",
      "verify_shard_checksums": true
    },
    "runtime_image": {
      "repository": "ghcr.io/mah5472651/aeitron-agentic-ai",
      "python_version": "3.12",
      "pytorch_version": "2.10",
      "cuda_version": "12.8",
      "require_digest_pin": true
    },
    "scheduler_policy": {
      "namespace": "aeitron-training",
      "queue": "gpu-training",
      "account": null,
      "storage_class": "aeitron-checkpoints",
      "shared_checkpoint_claim": "aeitron-training-checkpoints",
      "priority_class": "aeitron-training-normal",
      "gang_scheduling": false,
      "topology_key": "kubernetes.io/hostname"
    },
    "cost_quota": {
      "maximum_gpu_hours": 24.0,
      "maximum_cost_usd": 500.0,
      "estimated_gpu_hour_cost_usd": 3.0,
      "maximum_storage_gib": 500,
      "maximum_egress_gib": 0,
      "maximum_concurrent_jobs_per_owner": 1
    },
    "immutable_inputs": {
      "require_promoted_dataset": true,
      "require_dataset_sha256": true,
      "require_tokenizer_sha256": true,
      "allowed_uri_schemes": ["s3"]
    }
  },
