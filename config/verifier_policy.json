{
  "schema_version": 2,
  "default_profile": "fast",
  "production_profile": "release",
  "profiles": {
    "fast": {
      "name": "fast",
      "description": "Local fast verifier for development: native rules plus secret scan; no external scanner dependency.",
      "run_rule_security": true,
      "run_secret_scan": true,
      "run_multilang_security": false,
      "run_semgrep": false,
      "run_codeql": false,
      "run_sandbox": false,
      "semgrep_config": "auto",
      "codeql_language": "python",
      "codeql_suite": "codeql/python-queries",
      "sandbox_command": "python3 -m pytest -q",
      "allowed_command_roots": [
        "python",
        "python3",
        "pytest"
      ],
      "timeout_ms": 60000,
      "fail_on_medium": true,
      "fail_on_tool_unavailable": false,
      "max_files": 600,
      "exclude_patterns": [],
      "production_ready": false
    },
    "security": {
