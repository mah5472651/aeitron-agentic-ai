{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schemas/grpo-record-v1.json",
  "title": "Mythos Verified GRPO Group",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt", "candidates", "metadata"],
  "properties": {
    "prompt": {"type": "string", "minLength": 1},
    "candidates": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["response", "reward", "reward_components"],
        "properties": {
          "response": {"type": "string", "minLength": 1},
          "reward": {"type": "number"},
          "reward_components": {
            "type": "object",
            "required": ["execution", "security", "format", "efficiency"]
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["sandbox_verified", "source_run_id"],
      "properties": {
        "sandbox_verified": {"const": true},
        "source_run_id": {"type": "string", "minLength": 1}
      }
    }
  }
}

