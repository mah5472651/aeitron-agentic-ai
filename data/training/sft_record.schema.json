{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos.local/schemas/sft-record-v1.json",
  "title": "Mythos Verified SFT Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt", "chosen", "metadata"],
  "properties": {
    "prompt": {"type": "string", "minLength": 1},
    "chosen": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "required": ["verifier_status", "first_pass", "source_run_id"],
      "properties": {
        "verifier_status": {"const": "passed"},
        "first_pass": {"const": true},
        "source_run_id": {"type": "string", "minLength": 1},
        "review_status": {"enum": ["approved", "auto_verified"]},
        "security_status": {"enum": ["passed", "not_applicable"]}
      }
    }
  }
}

