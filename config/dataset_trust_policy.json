{
  "schema_version": 1,
  "policy_id": "aeitron-dataset-trust-v1",
  "scratch_only": true,
  "source_limits": {
    "new_source_max_token_fraction": 0.01,
    "source_max_token_fraction": 0.2,
    "source_family_max_token_fraction": 0.35,
    "minimum_reviewed_records": 100,
    "minimum_reputation_lower_bound": 0.7
  },
  "review": {
    "high_value_requires_two_reviewers": true,
    "reviewer_agreement_minimum": 0.8,
    "sampled_acceptance_minimum": 0.95,
    "routine_sample_fraction": 0.03,
    "blind_review": true,
    "independent_reviewer_identities": true
  },
  "promotion": {
    "minimum_records": 100000,
    "minimum_average_quality": 0.8,
    "minimum_p10_quality": 0.7,
    "maximum_residual_near_duplicate_fraction": 0.005,
    "maximum_benchmark_contamination": 0,
    "maximum_secret_or_pii_hits": 0,
    "required_license_coverage": 1.0,
    "required_provenance_coverage": 1.0,
    "required_high_value_review_coverage": 1.0,
    "required_verified_patch_evidence_coverage": 1.0
  },
  "protected_holdout_names": [
    "aeitron-repository-qualification",
    "cyberseceval",
    "humaneval",
    "livecodebench",
    "mbpp",
    "swe-bench"
  ],
  "high_value_data_types": [
    "debug_trace",
    "patch",
    "security_advisory",
    "security_reference",
    "test",
    "verified_security_patch"
  ],
  "split_group_keys": [
    "repository",
    "project_family",
    "vulnerability_family",
    "source_family",
    "document_family",
    "patch_lineage",
    "task_signature"
  ],
  "forbidden_content_classes": [
    "autonomous_live_target_attack",
    "credential_theft",
    "malware_persistence",
    "private_credential",
    "protected_benchmark_solution",
    "unbounded_malware_execution"
  ]
}
